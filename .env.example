# 本地配置文件模板
# 复制本文件为 .env（同目录）并按需修改。.env 已被 .gitignore 忽略，可放心写入本地路径。
# 在终端 / 系统设置的环境变量优先级更高，会覆盖此处同名项。

# 模型路径：bge-m3 模型目录。可写相对项目路径（如 model/bge-m3）或绝对路径。
# 留空则自动使用项目内 model/bge-m3（默认位置，无需设置）。
DANBOORU_MODEL_PATH=

# 推理设备：auto（有 GPU 用 GPU，否则 CPU）/ cpu / cuda
DANBOORU_DEVICE=auto

# NiceGUI 热重载：1 开启（开发用），默认关闭（避免报错后反复重启导致难以退出）
DANBOORU_RELOAD=0

# HuggingFace 镜像（国内加速模型下载）：https://hf-mirror.com
HF_ENDPOINT=

# 绑定地址与端口：Docker / 反向代理场景设为 0.0.0.0 并配合 7860 对外暴露；
# 本地直接运行保持默认即可（get_host_port() 读取这两个变量）。
DANBOORU_HOST=127.0.0.1
DANBOORU_PORT=11111
