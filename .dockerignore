# ── 版本控制 / 本地环境 ──
.git
.gitignore
*.md
.env
.env.example
CLAUDE.md
AGENTS.md
legacy_history.json

# ── Python 缓存与虚拟环境 ──
__pycache__
*.pyc
.venv
uv.lock
tests/
eval/
tempsave/

# ── 大型二进制（不进镜像，运行时下载 / 生成）──
